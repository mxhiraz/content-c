ANTHROPIC_API_KEY=sk-ant-...

# Image provider — "gemini" (default, Nano Banana Pro) or "fal" (gpt-image-2)
IMAGE_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview
FAL_KEY=

# Brand
BRAND_HANDLE=@unfoldedai
BRAND_HIGHLIGHT_COLOR=#A855F7

# Pipeline
MAX_ARTICLES_PER_RUN=3
LOOKBACK_HOURS=24
OUTPUT_DIR=./out
# Total slides per carousel (hook + body + cta). Min 4, max 10.
MAX_SLIDES=4

# Render

# composite | gemini
HOOK_RENDERER=composite

# canvas | gemini  (canvas = no AI, pure source photo + canvas text. gemini = AI polish on canvas base)
HOOK_TYPOGRAPHY=canvas

# panel | overlay | magazine
HOOK_STYLE=overlay

# gemini | composite
BODY_RENDERER=gemini

RENDER_CONCURRENCY=8

# Browser-rendered scraping for JS-heavy news pages (NYT, Bloomberg, X)
# Requires: npm i playwright && npx playwright install chromium
BROWSER_SCRAPE=true

# Nitter instances for free X/Twitter scraping (comma-separated, fallback chain)
NITTER_INSTANCES=nitter.net,nitter.poast.org,nitter.privacydev.net,nitter.kavin.rocks

# Video (requires ffmpeg + yt-dlp: brew install ffmpeg yt-dlp)
# Chain: source URL -> Claude-found related video URLs -> official entity X handle (Nitter+yt-dlp) -> yt-dlp YouTube search
SOURCE_VIDEO=true
VIDEO_COVER=true
VIDEO_BODY=true

# YouTube search fallback (last resort, official-channel scorer reduces copyright risk)
YOUTUBE_SEARCH=true

# Queue server (BullMQ + bull-board dashboard)
QUEUE_PORT=3000
REDIS_URL=redis://redis:6379

# SMTP delivery (Gmail: get an "app password" from myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# WhatsApp config UI port
CONFIG_PORT=8080

# Schedule cron expressions (TZ-aware via TZ= prefix). Default = 5 daily slots IST.
SCHEDULE_TZ=Asia/Kolkata
# Crons start 7 min before delivery target. Default = deliver at 1pm,3pm,5:45pm,6:45pm,7:30pm IST.
SCHEDULE_CRONS=53 12 * * *,53 14 * * *,38 17 * * *,38 18 * * *,23 19 * * *

# Newsletter watcher — polls human-curated AI newsletter RSS feeds for hot picks
NEWSLETTER_INTERVAL=0 */6 * * *
NEWSLETTER_MAX_PER_RUN=1
NEWSLETTER_FEEDS=https://www.bensbites.com/rss,https://alphasignal.ai/rss,https://tldr.tech/ai/rss,https://huggingface.co/blog/feed.xml

# ============ NICHE CONFIG (swap for non-AI niches) ============

# Niche label — playbook auto-researches copywriting + viral patterns for this niche
NICHE=AI/tech

# X handles to monitor for breaking posts (no @ prefix)
WATCH_X_HANDLES=AnthropicAI,OpenAI,GoogleDeepMind,sama,karpathy,ylecun,kimmonismus,iruletheworldmo,aidan_mclau,swyx,dario_amodei

# Reddit subs. Format: subname:feed
WATCH_REDDIT_SUBS=singularity:viral,LocalLLaMA:latest,MachineLearning:latest,ChatGPT:viral,PromptEngineering:prompts
WATCH_REDDIT_MIN_UPVOTES=400

# YouTube official channels (disambig scorer boost). Lowercase, comma-separated.
YOUTUBE_OFFICIAL_CHANNELS=openai,anthropic,anthropicai,google,googledeepmind,deepmind,meta,metaai,nvidia,tesla,bbcnews,reuters,techcrunch,theverge,bloomberg,wsj
